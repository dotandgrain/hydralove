DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Web Push VAPID keys.
# VAPID_PUBLIC_KEY is read at runtime by /api/push-public-key.
# NEXT_PUBLIC_VAPID_PUBLIC_KEY is kept for older builds / compatibility.
VAPID_PUBLIC_KEY=""
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_EMAIL="mailto:your-email@example.com"

CRON_SECRET="replace-this-with-a-long-random-secret"
